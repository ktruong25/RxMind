NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://rxmind:rxmind@localhost:5432/rxmind

# JWT (legacy - replaced by Clerk, kept for migration period)
JWT_SECRET=change_me_32_chars_minimum

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourpharmacy.com

# PioneerRx PMS
PIONEERRX_BASE_URL=https://api.pioneerrx.com/v1
PIONEERRX_API_KEY=
PIONEERRX_PHARMACY_ID=

# CSV flat-file polling
CSV_WATCH_DIR=/data/pms-exports
CSV_POLL_INTERVAL_MS=60000
